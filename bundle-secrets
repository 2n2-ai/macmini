#!/bin/bash
set -e

# bundle-secrets — Package OpenClaw secrets into an encrypted zip for transfer
# https://github.com/2n2-ai/macmini

fancy_echo() {
  local fmt="$1"; shift
  # shellcheck disable=SC2059
  printf "\\n==> $fmt\\n" "$@"
}

OPENCLAW_DIR="$HOME/.openclaw"
BUNDLE="$OPENCLAW_DIR/secrets-bundle.zip"
TMPDIR_BUNDLE="$(mktemp -d)"

fancy_echo "Bundling secrets from ~/.openclaw..."

# Collect files that exist
FILES=()
for f in openclaw.json secrets.json .env exec-approvals.json; do
  [[ -f "$OPENCLAW_DIR/$f" ]] && FILES+=("$f")
done

# Collect directories that exist
for d in credentials wallet identity .config; do
  [[ -d "$OPENCLAW_DIR/$d" ]] && FILES+=("$d")
done

if [[ ${#FILES[@]} -eq 0 ]]; then
  echo "  No secrets found in ~/.openclaw. Nothing to bundle."
  exit 0
fi

echo "  Bundling:"
for f in "${FILES[@]}"; do
  echo "    $f"
done
echo ""

# Create zip with password
cd "$OPENCLAW_DIR"
zip -r -e "$BUNDLE" "${FILES[@]}"

echo ""
fancy_echo "Bundle created: $BUNDLE"
echo ""
echo "  Transfer this file to your new machine via AirDrop, USB, or scp."
echo "  Then run: bash setup (and choose 'import secrets bundle')"
echo ""
