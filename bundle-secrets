#!/bin/bash
set -e

# bundle-secrets — Package S-tier secrets into a zip for AirDrop/USB transfer
# https://github.com/2n2-ai/macmini

fancy_echo() {
  local fmt="$1"; shift
  # shellcheck disable=SC2059
  printf "\\n==> $fmt\\n" "$@"
}

OPENCLAW_DIR="${1:-$HOME/.openclaw}"
BUNDLE="$HOME/Desktop/openclaw-secrets.zip"

fancy_echo "Bundling S-tier secrets from ~/.openclaw..."

# Only S-tier files — no openclaw.json (config, not secrets)
FILES=()
for f in secrets.json .env; do
  [[ -f "$OPENCLAW_DIR/$f" ]] && FILES+=("$f")
done
for d in credentials wallet identity .config; do
  [[ -d "$OPENCLAW_DIR/$d" ]] && FILES+=("$d")
done

# Exclude junk from .config
EXCLUDES="-x *.dmp -x */Crash?Reports/* -x */Cache/* -x */GPUCache/*"

if [[ ${#FILES[@]} -eq 0 ]]; then
  echo "  No secrets found. Nothing to bundle."
  exit 0
fi

echo "  Bundling:"
for f in "${FILES[@]}"; do
  echo "    $f"
done
echo ""

cd "$OPENCLAW_DIR"
# shellcheck disable=SC2086
zip -r -e "$BUNDLE" "${FILES[@]}" $EXCLUDES

echo ""
fancy_echo "Bundle saved to Desktop: openclaw-secrets.zip"
echo ""
echo "  AirDrop this file to the new Mac Mini."
echo "  The setup wizard will ask for its path."
echo ""
