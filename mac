#!/bin/bash
set -e

# macmini — Bootstrap a Mac Mini into a native OpenClaw machine
# https://github.com/2n2-ai/macmini
#
# Runs thoughtbot/laptop first, then layers on OpenClaw-specific tools
# via ~/.laptop.local.

MACMINI_REPO="https://raw.githubusercontent.com/2n2-ai/macmini/main"
MACMINI_LOG="$HOME/macmini.log"
exec > >(tee -a "$MACMINI_LOG") 2>&1

echo ""
echo "macmini bootstrap — $(date)"
echo "Log: $MACMINI_LOG"
echo ""

fancy_echo() {
  local fmt="$1"; shift
  # shellcheck disable=SC2059
  printf "\\n==> $fmt\\n" "$@"
}

# ---------------------------------------------------------------------------
# 1. macOS software update
# ---------------------------------------------------------------------------
fancy_echo "Checking for macOS updates..."
UPDATE_COUNT=$(softwareupdate -l 2>&1 | grep -c "^\*" || true)
if [[ "$UPDATE_COUNT" -gt 0 ]]; then
  fancy_echo "Installing macOS updates (this may take a while)..."
  softwareupdate --install --all --agree-to-license
  echo ""
  echo "    If a restart is required, reboot and re-run this script."
  echo "    Press ENTER to continue (or Ctrl-C to reboot first)."
  echo ""
  read -r
fi

# ---------------------------------------------------------------------------
# 2. Install ~/.laptop.local (OpenClaw layer)
# ---------------------------------------------------------------------------
fancy_echo "Installing ~/.laptop.local..."
curl -fsSL "$MACMINI_REPO/laptop.local" -o "$HOME/.laptop.local"

# ---------------------------------------------------------------------------
# 3. Run thoughtbot/laptop
# ---------------------------------------------------------------------------
fancy_echo "Running thoughtbot/laptop..."
curl -fsSL https://raw.githubusercontent.com/thoughtbot/laptop/main/mac -o /tmp/thoughtbot-laptop
bash /tmp/thoughtbot-laptop

# ---------------------------------------------------------------------------
# Done
# ---------------------------------------------------------------------------
# Reload PATH so tools are available immediately
# (Don't source full .zshrc — it contains zsh-only syntax)
if [[ "$(uname -m)" == "arm64" ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
else
  eval "$(/usr/local/bin/brew shellenv)"
fi
eval "$(mise activate bash)"

fancy_echo "Layer 1 (Environment) complete!"
echo ""
echo "  Next: run the setup wizard:"
echo ""
echo "       git clone https://github.com/2n2-ai/macmini.git ~/macmini"
echo "       bash ~/macmini/setup"
echo ""
echo "  This walks you through:"
echo "    - Layer 2: Agent DNA (skills, persona, behaviors)"
echo "    - Layer 3: Instance (company identity, memory, credentials)"
echo "    - Secrets transfer"
echo "    - Gateway installation"
echo ""
echo "  Log: $MACMINI_LOG"
echo ""
