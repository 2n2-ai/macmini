#!/bin/bash
set -e

# restore — Restore an OpenClaw instance from a Restic backup on Backblaze B2
# https://github.com/openclaw/macmini

MACMINI_LOG="$HOME/macmini.log"
exec > >(tee -a "$MACMINI_LOG") 2>&1

echo ""
echo "macmini restore — $(date)"
echo ""

fancy_echo() {
  local fmt="$1"; shift
  # shellcheck disable=SC2059
  printf "\\n==> $fmt\\n" "$@"
}

# ---------------------------------------------------------------------------
# 1. Collect credentials
# ---------------------------------------------------------------------------
fancy_echo "Restic backup credentials"
echo ""
echo "  You need three values (from your password manager):"
echo "    - Restic repository password"
echo "    - Backblaze B2 Account ID"
echo "    - Backblaze B2 Account Key"
echo ""

# Try Keychain first, prompt if not found
RESTIC_PASSWORD=$(security find-generic-password -a restic -s openclaw-backup -w 2>/dev/null || true)
if [[ -z "$RESTIC_PASSWORD" ]]; then
  read -rsp "Restic password: " RESTIC_PASSWORD
  echo ""
fi

B2_ACCOUNT_ID=$(security find-generic-password -a b2 -s openclaw-backup-id -w 2>/dev/null || true)
if [[ -z "$B2_ACCOUNT_ID" ]]; then
  read -rp "B2 Account ID: " B2_ACCOUNT_ID
fi

B2_ACCOUNT_KEY=$(security find-generic-password -a b2 -s openclaw-backup-key -w 2>/dev/null || true)
if [[ -z "$B2_ACCOUNT_KEY" ]]; then
  read -rsp "B2 Account Key: " B2_ACCOUNT_KEY
  echo ""
fi

export RESTIC_PASSWORD B2_ACCOUNT_ID B2_ACCOUNT_KEY

RESTIC_BUCKET="${RESTIC_BUCKET:-openclaw-backup}"
export RESTIC_REPOSITORY="b2:${RESTIC_BUCKET}:/"

# ---------------------------------------------------------------------------
# 2. Store credentials in Keychain
# ---------------------------------------------------------------------------
fancy_echo "Storing credentials in macOS Keychain..."
security add-generic-password -a restic -s openclaw-backup -w "$RESTIC_PASSWORD" -U 2>/dev/null || true
security add-generic-password -a b2 -s openclaw-backup-id -w "$B2_ACCOUNT_ID" -U 2>/dev/null || true
security add-generic-password -a b2 -s openclaw-backup-key -w "$B2_ACCOUNT_KEY" -U 2>/dev/null || true

# ---------------------------------------------------------------------------
# 3. List available snapshots
# ---------------------------------------------------------------------------
fancy_echo "Available snapshots:"
restic snapshots --tag openclaw

echo ""
read -rp "Restore latest snapshot? [Y/n] " CONFIRM
if [[ "$CONFIRM" =~ ^[Nn] ]]; then
  echo "Aborted."
  exit 0
fi

# ---------------------------------------------------------------------------
# 4. Restore
# ---------------------------------------------------------------------------
fancy_echo "Restoring ~/.openclaw from latest snapshot..."
restic restore latest --target / --tag openclaw

# ---------------------------------------------------------------------------
# 5. Re-clone projects from manifest
# ---------------------------------------------------------------------------
MANIFEST="$HOME/.openclaw/workspace/projects.manifest"
if [[ -f "$MANIFEST" ]]; then
  fancy_echo "Re-cloning projects from manifest..."
  while IFS='|' read -r dir repo branch; do
    [[ -z "$dir" || "$dir" == \#* ]] && continue
    TARGET="$HOME/.openclaw/workspace/projects/$dir"
    if [[ -d "$TARGET/.git" ]]; then
      fancy_echo "Already exists: %s" "$dir"
    else
      fancy_echo "Cloning %s..." "$dir"
      git clone --branch "${branch:-main}" "$repo" "$TARGET"
    fi
  done < "$MANIFEST"
else
  echo ""
  echo "  No projects.manifest found. You can re-clone projects manually."
fi

# ---------------------------------------------------------------------------
# 6. Reinstall extensions
# ---------------------------------------------------------------------------
CLAWROUTER_DIR="$HOME/.openclaw/extensions/clawrouter"
if [[ -f "$CLAWROUTER_DIR/package.json" ]]; then
  fancy_echo "Reinstalling ClawRouter dependencies..."
  cd "$CLAWROUTER_DIR" && npm install
fi

# ---------------------------------------------------------------------------
# Done
# ---------------------------------------------------------------------------
fancy_echo "Restore complete!"
echo ""
echo "  Next: run 'openclaw gateway restart' to pick up the restored config."
echo ""
echo "  Log: $MACMINI_LOG"
echo ""
