# ~/.laptop.local — OpenClaw additions for thoughtbot/laptop
#
# This file is sourced at the end of thoughtbot's laptop script.
# Everything from laptop is already installed: Homebrew, git, gh,
# Node.js, Ruby (via asdf), tmux, etc.
#
# We add the OpenClaw-specific tools on top.

fancy_echo "Installing OpenClaw layer..."

# ---------------------------------------------------------------------------
# Helpers (not exported by thoughtbot/laptop)
# ---------------------------------------------------------------------------
append_to_file() {
  local file="$1" text="$2"
  if ! grep -Fqs "$text" "$file"; then
    printf '%s\n' "$text" >> "$file"
  fi
}

brew_install_or_upgrade() {
  if brew list --formula 2>/dev/null | grep -q "^$1\$"; then
    if brew outdated --formula 2>/dev/null | grep -q "^$1"; then
      fancy_echo "Upgrading %s..." "$1"
      brew upgrade "$1"
    else
      fancy_echo "Already installed: %s" "$1"
    fi
  else
    fancy_echo "Installing %s..." "$1"
    brew install "$1"
  fi
}

brew_cask_install() {
  if brew list --cask 2>/dev/null | grep -q "^$1\$"; then
    fancy_echo "Already installed: %s" "$1"
  else
    fancy_echo "Installing %s..." "$1"
    brew install --cask "$1"
  fi
}

npm_install_global() {
  if npm list -g "$1" &>/dev/null; then
    fancy_echo "Updating %s..." "$1"
    npm install -g "$1@latest"
  else
    fancy_echo "Installing %s..." "$1"
    npm install -g "$1@latest"
  fi
}

# ---------------------------------------------------------------------------
# CLI tools
# ---------------------------------------------------------------------------
brew_install_or_upgrade "himalaya"
brew_install_or_upgrade "cloudflared"
brew_install_or_upgrade "flyctl"
brew_install_or_upgrade "python3"
brew_install_or_upgrade "mise"

# ---------------------------------------------------------------------------
# Applications
# ---------------------------------------------------------------------------
brew_cask_install "google-chrome"
brew_cask_install "tailscale"
brew_cask_install "slack"
brew_cask_install "discord"
brew_cask_install "telegram"
brew_cask_install "1password"

# ---------------------------------------------------------------------------
# mise runtimes
# ---------------------------------------------------------------------------
fancy_echo "Configuring mise..."

append_to_file "$HOME/.zshrc" 'eval "$(mise activate zsh)"'
eval "$(mise activate bash)"

NODE_MAJOR="${NODE_MAJOR:-24}"
mise use --global "node@${NODE_MAJOR}"
mise use --global ruby@latest

fancy_echo "mise Node.js %s  /  Ruby %s" "$(node --version)" "$(ruby --version)"

# ---------------------------------------------------------------------------
# Shell aliases for workspace git repos
# ---------------------------------------------------------------------------
append_to_file "$HOME/.zshrc" "alias dna='git --git-dir=\$HOME/.openclaw/dna.git --work-tree=\$HOME/.openclaw/workspace'"
append_to_file "$HOME/.zshrc" "alias instance='git --git-dir=\$HOME/.openclaw/instance.git --work-tree=\$HOME/.openclaw/workspace'"

# ---------------------------------------------------------------------------
# Global npm packages
# ---------------------------------------------------------------------------
fancy_echo "Installing global npm packages..."

npm_install_global "openclaw"
npm_install_global "@anthropic-ai/claude-code"
npm_install_global "pnpm"
npm_install_global "vercel"
npm_install_global "mcporter"
